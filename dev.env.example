# Copy this file to dev.env and fill in your credentials.
# dev.env is loaded automatically by config.load_config() and is gitignored.

# ── OpenAI (teacher LLM for synthetic data generation) ──────────────
OPENAI_API_KEY=

# ── HuggingFace (storage buckets, dataset access) ───────────────────
HF_TOKEN=
LLM3D_STORAGE__HF_BUCKET=llm3d-data
LLM3D_STORAGE__HF_BUCKET_NAMESPACE=

# ── Modal (Blender sandbox & reward API) ─────────────────────────────
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ── Modal Reward API (set after deploying with `modal deploy`) ───────
LLM3D_MODAL__ENDPOINT=
LLM3D_MODAL__AUTH_TOKEN=

# ── Reward API server-side token (set via Modal Secrets) ─────────────
REWARD_API_TOKEN=

# ── Tinker (training platform) ──────────────────────────────────────
TINKER_API_KEY=

# ── Weights & Biases (optional, for experiment tracking) ─────────────
WANDB_API_KEY=
